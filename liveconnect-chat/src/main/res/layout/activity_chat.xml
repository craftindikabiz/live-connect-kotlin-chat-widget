<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/lc_background">

    <!-- Header -->
    <include
        android:id="@+id/chatHeader"
        layout="@layout/view_chat_header" />

    <!-- Tab layout -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/lc_white"
        app:tabMode="fixed"
        app:tabGravity="fill"
        app:tabIndicatorColor="@color/lc_primary"
        app:tabSelectedTextColor="@color/lc_primary"
        app:tabTextColor="@color/lc_text_hint" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/lc_border" />

    <!-- ViewPager for tabs -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>
