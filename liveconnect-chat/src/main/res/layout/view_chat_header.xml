<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="56dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingHorizontal="16dp"
    android:background="@color/lc_white">

    <!-- Avatar -->
    <FrameLayout
        android:layout_width="36dp"
        android:layout_height="36dp">

        <ImageView
            android:id="@+id/headerAvatar"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:scaleType="centerCrop"
            android:contentDescription="Widget icon" />
    </FrameLayout>

    <!-- Title (single line — matches Flutter EnhancedChatHeader) -->
    <TextView
        android:id="@+id/headerTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="12dp"
        android:text="@string/lc_header_title"
        android:textColor="@color/lc_text_primary"
        android:textSize="@dimen/lc_header_title_size"
        android:textStyle="bold"
        android:maxLines="1"
        android:ellipsize="end" />

    <!-- Menu button (3-dot) — toggled in code based on tab + active ticket -->
    <ImageButton
        android:id="@+id/headerMenuButton"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/lc_ic_more_vert"
        android:contentDescription="More options"
        android:visibility="gone"
        android:scaleType="center" />

    <!-- Close button -->
    <ImageButton
        android:id="@+id/headerCloseButton"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/lc_ic_close"
        android:contentDescription="@string/lc_close"
        android:scaleType="center" />

</LinearLayout>
